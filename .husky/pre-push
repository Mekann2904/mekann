#!/usr/bin/env sh
set -e

# Git hooks can run with a sanitized PATH. Include common Homebrew paths so
# project scripts use modern bash and npm when available.
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

if ! command -v npm >/dev/null 2>&1; then
  export NVM_DIR="${NVM_DIR:-$HOME/.config/nvm}"
  if [ -s "$NVM_DIR/nvm.sh" ]; then
    # Git hooks often run with a minimal PATH. Load nvm so npm is available
    # even when the hook is triggered from a GUI or a sanitized environment.
    . "$NVM_DIR/nvm.sh"
    nvm use --silent >/dev/null 2>&1 || true
  fi
fi

if ! command -v npm >/dev/null 2>&1; then
  echo "error: npm command not found. Install Node.js/npm or ensure nvm is available at \$NVM_DIR." >&2
  exit 127
fi

npm run prepush
