{
  "name": "pi-mekann-extensions",
  "version": "0.3.1",
  "description": "mekann extensions package for pi",
  "engines": {
    "node": ">=20.18.1"
  },
  "files": [
    ".pi/extensions",
    "!.pi/extensions/web-ui/node_modules",
    ".pi/lib",
    ".pi/skills",
    ".pi/APPEND_SYSTEM.md",
    ".pi/INDEX.md",
    ".pi/NAVIGATION.md",
    ".pi/themes",
    "AGENTS.md",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sinclair/typebox": "^0.34.48",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^11.10.0",
    "hono": "^4.12.3",
    "tsx": "^4.21.0",
    "web-tree-sitter": "^0.26.5",
    "yaml": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@mariozechner/pi-ai": "^0.53.0",
    "@mariozechner/pi-coding-agent": "^0.53.0",
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.22.0",
    "fast-check": "^4.5.3",
    "globals": "^16.0.0",
    "patch-package": "^8.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "scripts": {
    "postinstall": "echo \"postinstall patching disabled\"",
    "build": "vitest run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:watch": "vitest tests/e2e",
    "test:all": "vitest run",
    "typecheck": "tsc --noEmit --project tsconfig-check.json",
    "lint": "eslint .pi/extensions .pi/lib --max-warnings=0",
    "lint:fix": "eslint .pi/extensions .pi/lib --fix",
    "ci": "npm run typecheck && npm run lint && npm run test",
    "generate-abdd": "npx tsx scripts/generate-abdd.ts",
    "add-abdd-header": "npx tsx scripts/add-abdd-header.ts"
  },
  "pi": {
    "extensions": [
      "./.pi/extensions/abbr.ts",
      "./.pi/extensions/abdd.ts",
      "./.pi/extensions/pi-ai-abort-fix.ts",
      "./.pi/extensions/pi-coding-agent-rate-limit-fix.ts",
      "./.pi/extensions/pi-coding-agent-lock-fix.ts",
      "./.pi/extensions/agent-idle-indicator.ts",
      "./.pi/extensions/agent-runtime.ts",
      "./.pi/extensions/agent-usage-tracker.ts",
      "./.pi/extensions/append-system-loader.ts",
      "./.pi/extensions/autonomy-policy.ts",
      "./.pi/extensions/background-process.ts",
      "./.pi/extensions/code-structure-analyzer/extension.ts",
      "./.pi/extensions/code-viewer.ts",
      "./.pi/extensions/context-usage-dashboard.ts",
      "./.pi/extensions/cross-instance-runtime.ts",
      "./.pi/extensions/dynamic-tools.ts",
      "./.pi/extensions/enhanced-read.ts",
      "./.pi/extensions/github-agent.ts",
      "./.pi/extensions/playwright-cli.ts",
      "./.pi/extensions/inject-system-prompt.ts",
      "./.pi/extensions/invariant-pipeline.ts",
      "./.pi/extensions/kitty-status-integration.ts",
      "./.pi/extensions/loop.ts",
      "./.pi/extensions/mcp-client.ts",
      "./.pi/extensions/mediator.ts",
      "./.pi/extensions/plan.ts",
      "./.pi/extensions/question.ts",
      "./.pi/extensions/rate-limit-retry-budget.ts",
      "./.pi/extensions/repo-audit-orchestrator.ts",
      "./.pi/extensions/repograph-localization/index.ts",
      "./.pi/extensions/search/index.ts",
      "./.pi/extensions/skill-inspector.ts",
      "./.pi/extensions/startup-context.ts",
      "./.pi/extensions/subagents.ts",
      "./.pi/extensions/task.ts",
      "./.pi/extensions/task-flow.ts",
      "./.pi/extensions/task-auto-executor.ts",
      "./.pi/extensions/rpm-throttle.ts",
      "./.pi/extensions/tool-compiler.ts",
      "./.pi/extensions/workspace-verification.ts",
      "./.pi/extensions/ul-diagnostic.ts",
      "./.pi/extensions/ul-dual-mode.ts",
      "./.pi/extensions/ul-workflow.ts",
      "./.pi/extensions/usage-tracker.ts",
      "./.pi/extensions/web-ui/index.ts"
    ],
    "skills": [
      "./.pi/skills"
    ]
  }
}
